# ──────────────────────────────────────────
# Copy this file: cp terraform.tfvars.example terraform.tfvars
# Then edit the values below
# ──────────────────────────────────────────

region       = "us-east-1"
project_name = "myapp"
environment  = "dev"

# EC2
instance_type    = "t3.micro"
allowed_ssh_cidr = "YOUR_IP/32"    # Replace with your IP (check: curl ifconfig.me)
key_pair_name    = "my-key-pair"   # Create in AWS Console → EC2 → Key Pairs

# RDS
db_instance_class = "db.t3.micro"
db_name           = "appdb"
db_username       = "dbadmin"
db_password       = "CHANGE_ME_to_a_strong_password_123!"  # Min 8 chars
